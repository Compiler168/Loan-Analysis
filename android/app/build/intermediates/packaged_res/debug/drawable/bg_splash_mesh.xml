<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <gradient
                android:angle="135"
                android:endColor="#0F172A"
                android:startColor="#1E3A8A"
                android:type="linear" />
        </shape>
    </item>
    <item>
        <rotate
            android:fromDegrees="30"
            android:pivotX="10%"
            android:pivotY="10%"
            android:toDegrees="30">
            <shape android:shape="oval">
                <gradient
                    android:centerX="0.5"
                    android:centerY="0.5"
                    android:endColor="#00000000"
                    android:gradientRadius="400dp"
                    android:startColor="#1A60A5FA"
                    android:type="radial" />
            </shape>
        </rotate>
    </item>
    <item>
        <rotate
            android:fromDegrees="-45"
            android:pivotX="90%"
            android:pivotY="90%"
            android:toDegrees="-45">
            <shape android:shape="oval">
                <gradient
                    android:centerX="0.5"
                    android:centerY="0.5"
                    android:endColor="#00000000"
                    android:gradientRadius="500dp"
                    android:startColor="#1A10B981"
                    android:type="radial" />
            </shape>
        </rotate>
    </item>
</layer-list>