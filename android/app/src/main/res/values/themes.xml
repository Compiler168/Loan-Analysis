<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base App Theme (Light) -->
    <style name="Theme.SmartLoanAI" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorPrimaryVariant">@color/primary_variant</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@color/on_secondary</item>
        <item name="colorTertiary">@color/tertiary</item>
        <item name="colorOnTertiary">@color/on_tertiary</item>
        <item name="colorError">@color/error</item>
        <item name="colorOnError">@color/on_error</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="colorSurfaceVariant">@color/surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/on_surface_variant</item>
        <item name="android:statusBarColor">@color/surface</item>
        <item name="android:navigationBarColor">@color/surface</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">true</item>

        <!-- Default widget styles -->
        <item name="materialButtonStyle">@style/Widget.SmartLoan.Button</item>
        <item name="textInputStyle">@style/Widget.SmartLoan.TextInput</item>
        <item name="materialCardViewStyle">@style/Widget.SmartLoan.Card</item>
    </style>

    <!-- Auth Theme (Full screen gradient) -->
    <style name="Theme.SmartLoanAI.Auth" parent="Theme.SmartLoanAI">
        <item name="android:statusBarColor">#1E293B</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">false</item>
    </style>

    <!-- Button Style -->
    <style name="Widget.SmartLoan.Button" parent="Widget.Material3.Button">
        <item name="cornerRadius">12dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="Widget.SmartLoan.Button.Outline" parent="Widget.Material3.Button.OutlinedButton">
        <item name="cornerRadius">12dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- TextInput Style -->
    <style name="Widget.SmartLoan.TextInput" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">16dp</item>
        <item name="boxCornerRadiusTopEnd">16dp</item>
        <item name="boxCornerRadiusBottomStart">16dp</item>
        <item name="boxCornerRadiusBottomEnd">16dp</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">2dp</item>
        <item name="boxStrokeColor">@color/input_stroke</item>
        <item name="boxBackgroundColor">@color/input_bg</item>
        <item name="startIconTint">@color/primary</item>
        <item name="endIconTint">@color/text_secondary</item>
        <item name="hintTextColor">@color/primary</item>
        <item name="android:textColorHint">@color/text_muted</item>
        <item name="errorIconTint">@color/error</item>
        <item name="errorTextColor">@color/error</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.SmartLoan.SmallComponent</item>
    </style>

    <style name="ShapeAppearance.SmartLoan.SmallComponent" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerSize">16dp</item>
    </style>

    <style name="Widget.SmartLoan.Button.Social" parent="Widget.Material3.Button.OutlinedButton">
        <item name="cornerRadius">20dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="strokeColor">@color/card_stroke</item>
        <item name="strokeWidth">1.5dp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">14sp</item>
        <item name="rippleColor">@color/primary_light</item>
        <item name="android:backgroundTint">@color/white</item>
    </style>

    <style name="Widget.SmartLoan.Button.SocialIcon" parent="Widget.SmartLoan.Button.Social">
        <item name="android:padding">0dp</item>
        <item name="iconPadding">0dp</item>
        <item name="iconGravity">textStart</item>
    </style>

    <!-- Card Style -->
    <style name="Widget.SmartLoan.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">2dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/card_stroke</item>
        <item name="cardBackgroundColor">@color/card_background</item>
    </style>

    <!-- Text Styles -->
    <style name="TextStyle" />

    <style name="TextStyle.Heading1">
        <item name="android:textSize">28sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextStyle.Heading2">
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/on_surface</item>
    </style>

    <style name="TextStyle.Heading3">
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/on_surface</item>
    </style>

    <style name="TextStyle.Body">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/on_surface</item>
    </style>

    <style name="TextStyle.Caption">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/muted_foreground</item>
    </style>

    <style name="TextStyle.Label">
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/muted_foreground</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <!-- Stat Card Title -->
    <style name="TextStyle.StatValue">
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/on_surface</item>
    </style>

    <style name="ShapeAppearance.Circle" parent="">
        <item name="cornerSize">50%</item>
    </style>

    <style name="ShapeAppearance.MaterialComponents.SmallComponent" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerSize">12dp</item>
    </style>

    <!-- Chip Style -->
    <style name="Widget.SmartLoan.Chip" parent="Widget.Material3.Chip.Suggestion">
        <item name="chipCornerRadius">20dp</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="chipStrokeColor">@color/card_stroke</item>
    </style>

    <!-- Bottom Nav Style -->
    <style name="Widget.SmartLoan.BottomNav" parent="Widget.Material3.BottomNavigationView">
        <item name="itemIconTint">@color/bottom_nav_color</item>
        <item name="itemTextColor">@color/bottom_nav_color</item>
        <item name="itemActiveIndicatorStyle">@style/Widget.SmartLoan.BottomNav.ActiveIndicator</item>
    </style>

    <style name="Widget.SmartLoan.BottomNav.ActiveIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/nav_selected</item>
    </style>

</resources>
