<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:paddingVertical="4dp">

    <!-- Bot Message (Left) -->
    <LinearLayout android:id="@+id/botLayout" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:orientation="horizontal"
        android:gravity="start" android:visibility="gone">
        <View android:id="@+id/botAvatar" android:layout_width="32dp" android:layout_height="32dp"
            android:background="@drawable/bg_circle_gradient" android:layout_marginEnd="8dp" android:layout_marginTop="4dp" />
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:orientation="vertical">
            <TextView android:id="@+id/tvBotMessage" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:background="@drawable/bg_chat_bot" android:padding="12dp" android:textSize="14sp"
                android:textColor="@color/on_surface" android:maxWidth="280dp" />
            <LinearLayout android:id="@+id/suggestionsLayout" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:orientation="horizontal"
                android:layout_marginTop="4dp" android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>

    <!-- User Message (Right) -->
    <LinearLayout android:id="@+id/userLayout" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:orientation="horizontal"
        android:gravity="end" android:visibility="gone">
        <TextView android:id="@+id/tvUserMessage" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:background="@drawable/bg_chat_user" android:padding="12dp" android:textSize="14sp"
            android:textColor="@color/on_primary" android:maxWidth="280dp" />
    </LinearLayout>
</FrameLayout>
