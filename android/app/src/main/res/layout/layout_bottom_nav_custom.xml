<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/customBottomNavContainer"
    android:layout_width="match_parent"
    android:layout_height="72dp"
    android:background="@drawable/bg_bottom_nav"
    android:elevation="12dp"
    android:orientation="horizontal"
    android:paddingHorizontal="4dp">

    <!-- Dashboard -->
    <LinearLayout
        android:id="@+id/item_dashboard"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_weight="1"
        android:layout_gravity="center_vertical"
        android:layout_marginHorizontal="4dp"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical">
        <ImageView
            android:id="@+id/iv_dashboard"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_nav_dashboard"
            app:tint="@color/nav_icon_selected" />
        <TextView
            android:id="@+id/tv_dashboard"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/nav_dashboard"
            android:textSize="10sp"
            android:textColor="@color/nav_icon_selected"
            android:fontFamily="sans-serif-medium" />
    </LinearLayout>

    <!-- Prediction -->
    <LinearLayout
        android:id="@+id/item_prediction"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_weight="1"
        android:layout_gravity="center_vertical"
        android:layout_marginHorizontal="4dp"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical">
        <ImageView
            android:id="@+id/iv_prediction"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_nav_prediction"
            app:tint="@color/nav_icon_default" />
        <TextView
            android:id="@+id/tv_prediction"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/nav_prediction"
            android:textSize="10sp"
            android:textColor="@color/nav_icon_default" />
    </LinearLayout>

    <!-- AI Chat -->
    <LinearLayout
        android:id="@+id/item_chatbot"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_weight="1"
        android:layout_gravity="center_vertical"
        android:layout_marginHorizontal="4dp"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical">
        <ImageView
            android:id="@+id/iv_chatbot"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_nav_chat"
            app:tint="@color/nav_icon_default" />
        <TextView
            android:id="@+id/tv_chatbot"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/nav_chatbot"
            android:textSize="10sp"
            android:textColor="@color/nav_icon_default" />
    </LinearLayout>

    <!-- Analysis -->
    <LinearLayout
        android:id="@+id/item_analysis"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_weight="1"
        android:layout_gravity="center_vertical"
        android:layout_marginHorizontal="4dp"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical">
        <ImageView
            android:id="@+id/iv_analysis"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_nav_analysis"
            app:tint="@color/nav_icon_default" />
        <TextView
            android:id="@+id/tv_analysis"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/nav_analysis"
            android:textSize="10sp"
            android:textColor="@color/nav_icon_default" />
    </LinearLayout>

    <!-- Simulator -->
    <LinearLayout
        android:id="@+id/item_simulator"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_weight="1"
        android:layout_gravity="center_vertical"
        android:layout_marginHorizontal="4dp"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical">
        <ImageView
            android:id="@+id/iv_simulator"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_nav_simulator"
            app:tint="@color/nav_icon_default" />
        <TextView
            android:id="@+id/tv_simulator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/nav_simulator"
            android:textSize="10sp"
            android:textColor="@color/nav_icon_default" />
    </LinearLayout>

    <!-- Settings -->
    <LinearLayout
        android:id="@+id/item_profile"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_weight="1"
        android:layout_gravity="center_vertical"
        android:layout_marginHorizontal="4dp"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical">
        <ImageView
            android:id="@+id/iv_profile"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_nav_profile"
            app:tint="@color/nav_icon_default" />
        <TextView
            android:id="@+id/tv_profile"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/nav_settings"
            android:textSize="10sp"
            android:textColor="@color/nav_icon_default" />
    </LinearLayout>

</LinearLayout>